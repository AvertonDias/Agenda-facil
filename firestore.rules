rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regra para perfis de usuários
    match /perfis_usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regra para Empresas e Subcoleções (Abordagem Recursiva e Explícita)
    match /empresas/{empresaId} {
      // Permite ler e editar o documento da própria empresa
      allow read, write: if request.auth != null && request.auth.uid == empresaId;

      // Permite ler e editar QUALQUER subcoleção (agendamentos, servicos, colaboradores, etc.)
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == empresaId;
      }
    }
    
    // Bloqueio preventivo padrão para qualquer outro caminho
    match /{document=**} {
      allow read, write: if false;
    }
  }
}