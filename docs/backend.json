
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Perfil do usuário administrador ou cliente.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "client"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "displayName", "role"]
    },
    "Company": {
      "title": "Company",
      "type": "object",
      "description": "Dados do salão ou estabelecimento.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "plan": { "type": "string" },
        "workingHours": { "type": "object", "description": "Mapa de horários por dia da semana" },
        "offDays": { "type": "array", "items": { "type": "string" }, "description": "Lista de datas (YYYY-MM-DD) marcadas como folga ou férias" },
        "promotions": { "type": "array", "items": { "type": "string" } },
        "automaticPromotions": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" },
              "dayOfWeek": { "type": "string", "enum": ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday", "any"] },
              "serviceIds": { "type": "array", "items": { "type": "string" } },
              "discountPercentage": { "type": "number" }
            }
          }
        },
        "loyaltyEnabled": { "type": "boolean" },
        "loyaltyPointsPerVisit": { "type": "number" },
        "loyaltyGoal": { "type": "number" },
        "loyaltyReward": { "type": "string" },
        "minLeadTimeHours": { "type": "number" },
        "slotIntervalMinutes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "ownerId"]
    },
    "Service": {
      "title": "Service",
      "type": "object",
      "description": "Serviço oferecido pelo salão.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "basePrice": { "type": "number" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "name", "durationMinutes", "basePrice"]
    },
    "Collaborator": {
      "title": "Collaborator",
      "type": "object",
      "description": "Profissional da equipe.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "offeredServiceIds": { "type": "array", "items": { "type": "string" } },
        "workingHours": { "type": "object", "description": "Horários personalizados do profissional (opcional)" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "name"]
    },
    "Appointment": {
      "title": "Appointment",
      "type": "object",
      "description": "Agendamento de serviço com suporte a múltiplos serviços.",
      "properties": {
        "id": { "type": "string" },
        "salonId": { "type": "string", "description": "ID da empresa/salão" },
        "clientName": { "type": "string" },
        "clientPhone": { "type": "string" },
        "serviceIds": { "type": "array", "items": { "type": "string" }, "description": "Lista de IDs dos serviços selecionados" },
        "employeeId": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time", "description": "UTC Timestamp de início" },
        "endTime": { "type": "string", "format": "date-time", "description": "UTC Timestamp de fim" },
        "timezone": { "type": "string", "description": "Fuso horário original (ex: America/Sao_Paulo)" },
        "status": { "type": "string", "enum": ["pendente", "confirmado", "cancelado", "concluido", "nao_compareceu"] },
        "finalPrice": { "type": "number" }
      },
      "required": ["id", "clientName", "serviceIds", "employeeId", "startTime", "endTime", "timezone"]
    },
    "LoyaltyRecord": {
      "title": "LoyaltyRecord",
      "type": "object",
      "description": "Registro de pontos de fidelidade por cliente.",
      "properties": {
        "phone": { "type": "string" },
        "clientName": { "type": "string" },
        "points": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["phone", "points"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/perfis_usuarios/{userId}": {
      "schema": "UserProfile",
      "description": "Perfis de usuários"
    },
    "/empresas/{empresaId}": {
      "schema": "Company",
      "description": "Dados da empresa"
    },
    "/empresas/{empresaId}/servicos/{servicoId}": {
      "schema": "Service",
      "description": "Catálogo de serviços"
    },
    "/empresas/{empresaId}/colaboradores/{colaboradorId}": {
      "schema": "Collaborator",
      "description": "Equipe de profissionais"
    },
    "/empresas/{empresaId}/agendamentos/{agendamentoId}": {
      "schema": "Appointment",
      "description": "Registro de agendamentos"
    },
    "/empresas/{empresaId}/fidelidade/{phone}": {
      "schema": "LoyaltyRecord",
      "description": "Pontos de fidelidade por telefone"
    }
  }
}
