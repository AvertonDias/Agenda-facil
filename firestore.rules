/**
 * Firebase Firestore Security Rules
 *
 * Core Philosophy:
 * This ruleset enforces a strict ownership model. Access to company data
 * is granted if the company ID in the path matches the authenticated user's UID.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    // Perfis de usuários: Apenas o próprio usuário pode acessar seu perfil
    match /perfis_usuarios/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Empresas e suas subcoleções: 
    // O dono (UID correspondente ao ID do documento) tem acesso total à sua árvore de dados.
    match /empresas/{empresaId} {
      allow read, write: if isOwner(empresaId);

      // Permite acesso recursivo a todas as subcoleções (servicos, colaboradores, agendamentos, etc.)
      match /{allSubcollections=**} {
        allow read, write: if isOwner(empresaId);
      }
    }
    
    // Suporte para consultas públicas (ex: página de agendamento do cliente)
    // No futuro, você pode adicionar regras específicas aqui se quiser que clientes
    // listem serviços sem estarem logados.
  }
}