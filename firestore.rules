rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper para verificar se o usuário está logado
    function isSignedIn() {
      return request.auth != null;
    }

    // Perfis de usuários: Apenas o próprio usuário acessa seu perfil
    match /perfis_usuarios/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Regras explícitas para Empresas e suas subcoleções
    // O dono (empresaId == auth.uid) tem acesso total
    
    // 1. Documento da Empresa
    match /empresas/{empresaId} {
      allow read, write: if isSignedIn() && request.auth.uid == empresaId;
    }

    // 2. Subcoleção de Agendamentos (Onde ocorria o erro de listagem)
    match /empresas/{empresaId}/agendamentos/{docId} {
      allow read, write: if isSignedIn() && request.auth.uid == empresaId;
    }

    // 3. Subcoleção de Serviços
    match /empresas/{empresaId}/servicos/{docId} {
      allow read, write: if isSignedIn() && request.auth.uid == empresaId;
    }

    // 4. Subcoleção de Colaboradores
    match /empresas/{empresaId}/colaboradores/{docId} {
      allow read, write: if isSignedIn() && request.auth.uid == empresaId;
    }

    // Backup para qualquer outra subcoleção futura
    match /empresas/{empresaId}/{allSubcollections=**} {
      allow read, write: if isSignedIn() && request.auth.uid == empresaId;
    }
  }
}