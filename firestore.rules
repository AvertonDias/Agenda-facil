
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regra para perfis de usuários
    match /perfis_usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regra para Empresas e suas Subcoleções (Modelo Ultra-Explícito)
    match /empresas/{empresaId} {
      // Permite ler/escrever o documento da própria empresa
      allow get, list, write: if request.auth != null && request.auth.uid == empresaId;

      // Permite acesso específico a subcoleções críticas de agendamentos
      match /agendamentos/{docId} {
        allow get, list, write: if request.auth != null && request.auth.uid == empresaId;
      }
      
      // Permite acesso aos catálogos
      match /servicos/{docId} {
        allow get, list, write: if request.auth != null && request.auth.uid == empresaId;
      }
      
      match /colaboradores/{docId} {
        allow get, list, write: if request.auth != null && request.auth.uid == empresaId;
      }

      // Permite acesso recursivo total para qualquer outra subcoleção futura dentro da empresa
      match /{anything=**} {
        allow get, list, write: if request.auth != null && request.auth.uid == empresaId;
      }
    }
    
    // Bloqueio preventivo padrão para qualquer outro caminho não especificado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
