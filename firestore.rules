rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Regra para Perfis de Usuários
    match /perfis_usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 2. Regra para o DOCUMENTO da Empresa
    // Permite que a empresa acesse seus próprios dados básicos
    match /empresas/{empresaId} {
      allow read, write: if request.auth != null && request.auth.uid == empresaId;
    }

    // 3. Regra para QUALQUER coisa dentro de uma empresa (Subcoleções)
    // O curinga {anything=**} aplicado após o ID da empresa garante 
    // acesso total a agendamentos, servicos, etc.
    match /empresas/{empresaId}/{anything=**} {
      allow read, write: if request.auth != null && request.auth.uid == empresaId;
    }
    
    // Bloqueio preventivo para outras coleções
    match /{document=**} {
      allow read, write: if false;
    }
  }
}