/**
 * Firebase Firestore Security Rules - AgendaFácil Pro
 * 
 * Regras simplificadas e robustas para garantir acesso total ao proprietário.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper para verificar se o usuário está logado
    function isSignedIn() {
      return request.auth != null;
    }

    // Perfis de usuários: Apenas o próprio usuário acessa seu perfil
    match /perfis_usuarios/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Hierarquia de Empresas: O dono (UID == empresaId) tem acesso total e recursivo
    // a tudo que estiver dentro do caminho da sua empresa.
    match /empresas/{empresaId} {
      allow read, write: if isSignedIn() && request.auth.uid == empresaId;
      
      // Permite acesso total a qualquer documento ou subcoleção dentro da empresa
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == empresaId;
      }
    }
  }
}