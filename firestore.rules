/**
 * Firebase Firestore Security Rules - AgendaFácil Pro
 * 
 * Regras otimizadas para garantir acesso total ao proprietário do estabelecimento
 * baseado na hierarquia /empresas/{empresaId}/ onde empresaId == userId.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper para verificar se o usuário está logado
    function isSignedIn() {
      return request.auth != null;
    }

    // Regra para Perfis de Usuários
    match /perfis_usuarios/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Regras para Empresas e suas Subcoleções
    // O dono (empresaId) tem acesso total a tudo dentro de seu caminho
    match /empresas/{empresaId} {
      allow read, write: if isSignedIn() && request.auth.uid == empresaId;
      
      // Permissões explícitas para as subcoleções principais
      match /servicos/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == empresaId;
      }
      
      match /colaboradores/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == empresaId;
      }
      
      match /agendamentos/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == empresaId;
      }

      // Fallback para qualquer outra subcoleção futura
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == empresaId;
      }
    }
  }
}