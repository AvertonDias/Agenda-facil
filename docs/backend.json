{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Perfil do usuário administrador ou cliente.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "client"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "displayName", "role"]
    },
    "Company": {
      "title": "Company",
      "type": "object",
      "description": "Dados do salão ou estabelecimento.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "plan": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "ownerId"]
    },
    "Service": {
      "title": "Service",
      "type": "object",
      "description": "Serviço oferecido pelo salão.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "basePrice": { "type": "number" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "name", "durationMinutes", "basePrice"]
    },
    "Collaborator": {
      "title": "Collaborator",
      "type": "object",
      "description": "Profissional da equipe.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "offeredServiceIds": { "type": "array", "items": { "type": "string" } },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "name"]
    },
    "Appointment": {
      "title": "Appointment",
      "type": "object",
      "description": "Agendamento de serviço.",
      "properties": {
        "id": { "type": "string" },
        "clientName": { "type": "string" },
        "clientPhone": { "type": "string" },
        "serviceId": { "type": "string" },
        "employeeId": { "type": "string" },
        "date": { "type": "string", "description": "Formato YYYY-MM-DD" },
        "time": { "type": "string", "description": "Formato HH:mm" },
        "status": { "type": "string", "enum": ["pendente", "confirmado", "cancelado"] }
      },
      "required": ["id", "clientName", "serviceId", "employeeId", "date", "time"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/perfis_usuarios/{userId}": {
      "schema": "UserProfile",
      "description": "Perfis de usuários"
    },
    "/empresas/{empresaId}": {
      "schema": "Company",
      "description": "Dados da empresa"
    },
    "/empresas/{empresaId}/servicos/{servicoId}": {
      "schema": "Service",
      "description": "Catálogo de serviços"
    },
    "/empresas/{empresaId}/colaboradores/{colaboradorId}": {
      "schema": "Collaborator",
      "description": "Equipe de profissionais"
    },
    "/empresas/{empresaId}/agendamentos/{agendamentoId}": {
      "schema": "Appointment",
      "description": "Registro de agendamentos"
    }
  }
}