rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper para verificar se o usuário está logado
    function isSignedIn() {
      return request.auth != null;
    }

    // Perfis de usuários: Apenas o próprio usuário acessa seu perfil
    match /perfis_usuarios/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Hierarquia de Empresas: O dono (empresaId == auth.uid) tem acesso total
    match /empresas/{empresaId} {
      // Permite ler/escrever o documento da empresa
      allow read, write: if isSignedIn() && request.auth.uid == empresaId;
      
      // Permite ler/escrever em qualquer subcoleção ou documento abaixo da empresa
      // O uso de {allSubcollections=**} é a forma mais eficaz de garantir permissões de 'list'
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == empresaId;
      }
    }
  }
}