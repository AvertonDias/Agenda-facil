
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regra para Perfis de Usuários
    match /perfis_usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regra para o DOCUMENTO da Empresa e todas as suas SUBCOLEÇÕES (agendamentos, serviços, colaboradores)
    // O uso de {allPaths=**} garante que o proprietário tenha acesso a tudo abaixo de seu ID.
    match /empresas/{empresaId} {
      allow read, write: if request.auth != null && request.auth.uid == empresaId;
      
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == empresaId;
      }
    }
    
    // Bloqueio preventivo padrão
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
