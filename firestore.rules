rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper para verificar se o usuário está logado
    function isSignedIn() {
      return request.auth != null;
    }

    // Perfis de usuários: Apenas o próprio usuário acessa seu perfil
    match /perfis_usuarios/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Regras simplificadas e aninhadas para Empresas
    match /empresas/{empresaId} {
      // Permite ler/escrever o documento da própria empresa
      allow read, write: if isSignedIn() && request.auth.uid == empresaId;

      // Permite ler/escrever QUALQUER subcoleção (agendamentos, servicos, colaboradores, etc.)
      // desde que o usuário seja o dono da empresa pai
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == empresaId;
      }
    }
  }
}