
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regra para perfis
    match /perfis_usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regra para Empresas e Subcoleções (Modelo Ultra-Explícito e Recursivo)
    match /databases/{database}/documents/empresas/{empresaId} {
      // Permite ler/escrever o documento da empresa
      allow get, list, write: if request.auth != null && request.auth.uid == empresaId;

      // Permite acesso recursivo total a todas as subcoleções (agendamentos, servicos, colaboradores)
      // O curinga {anything=**} garante que listagem e leitura funcionem em qualquer profundidade
      match /{anything=**} {
        allow get, list, write: if request.auth != null && request.auth.uid == empresaId;
      }
    }
    
    // Bloqueio preventivo padrão
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
