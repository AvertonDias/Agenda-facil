rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Regra para Perfis de Usuários
    match /perfis_usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 2. Regra para o DOCUMENTO da Empresa
    match /empresas/{empresaId} {
      allow read, write: if request.auth != null && request.auth.uid == empresaId;
    }

    // 3. Regra para QUALQUER subcoleção ou documento dentro de uma empresa
    // O curinga recursivo {allPaths=**} garante que agendamentos, servicos, 
    // colaboradores, etc., sejam acessíveis se o UID do usuário for igual ao ID da empresa pai.
    match /empresas/{empresaId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == empresaId;
    }
    
    // Bloqueio padrão para segurança
    match /{document=**} {
      allow read, write: if false;
    }
  }
}