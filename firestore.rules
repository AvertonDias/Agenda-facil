
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regra para perfis de usuários
    match /perfis_usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regra para Empresas e suas Subcoleções
    match /empresas/{empresaId} {
      // Público pode ler informações básicas da empresa
      allow get: if true;
      allow write: if request.auth != null && request.auth.uid == empresaId;

      // Agendamentos
      match /agendamentos/{docId} {
        // Público pode criar agendamentos e listar para verificar disponibilidade de horários
        // Nota: Em produção, o ideal é não expor nomes/telefones, mas para o protótipo
        // isso permite que o motor de disponibilidade no cliente funcione.
        allow create, list, get: if true;
        // Apenas o dono pode gerenciar (update, delete)
        allow update, delete: if request.auth != null && request.auth.uid == empresaId;
      }
      
      // Serviços (Público precisa ver para escolher)
      match /servicos/{docId} {
        allow get, list: if true;
        allow write: if request.auth != null && request.auth.uid == empresaId;
      }
      
      // Colaboradores (Público precisa ver para escolher)
      match /colaboradores/{docId} {
        allow get, list: if true;
        allow write: if request.auth != null && request.auth.uid == empresaId;
      }

      // Fidelidade (Público pode ver seus próprios pontos via telefone ao finalizar agendamento)
      match /fidelidade/{phone} {
        allow get: if true;
        allow list, write: if request.auth != null && request.auth.uid == empresaId;
      }

      // Regra recursiva para o dono (Admin) ter acesso total a tudo da sua empresa
      match /{anything=**} {
        allow get, list, write: if request.auth != null && request.auth.uid == empresaId;
      }
    }
    
    // Bloqueio preventivo padrão
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
