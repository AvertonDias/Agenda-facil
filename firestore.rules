/**
 * Firebase Firestore Security Rules - AgendaFácil Pro
 * 
 * Regras explícitas para garantir que o dono da empresa tenha acesso total
 * aos seus próprios dados e subcoleções.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper para verificar se o usuário está logado
    function isSignedIn() {
      return request.auth != null;
    }

    // Perfis de usuários: Apenas o próprio usuário acessa seu perfil
    match /perfis_usuarios/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Hierarquia de Empresas
    match /empresas/{empresaId} {
      // O dono tem acesso ao documento da empresa
      allow read, write: if isSignedIn() && request.auth.uid == empresaId;
      
      // O dono tem acesso explícito às subcoleções (serviços, colaboradores, agendamentos)
      // O uso de allow read permite as operações 'get' e 'list'
      match /servicos/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == empresaId;
      }
      
      match /colaboradores/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == empresaId;
      }
      
      match /agendamentos/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == empresaId;
      }

      // Fallback para qualquer outra subcoleção futura
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == empresaId;
      }
    }
  }
}