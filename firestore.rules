/**
 * Firebase Firestore Security Rules
 *
 * Core Philosophy:
 * This ruleset enforces a strict ownership model. Access to company data
 * is granted if the company ID in the path matches the authenticated user's UID,
 * or if the user is identified as the owner in the document data.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isResourceOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isRequestOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isExistingOwner(ownerId) {
      return resource != null && isResourceOwner(ownerId);
    }

    // --- COLLECTION RULES ---

    match /perfis_usuarios/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /empresas/{empresaId} {
      // Permite acesso se o ID da empresa for o UID do usuário ou se ele for o owner no dado
      allow get, list: if isOwner(empresaId) || (resource != null && isResourceOwner(resource.data.ownerId));
      allow create: if isOwner(empresaId) || isRequestOwner(request.resource.data.ownerId);
      allow update, delete: if isOwner(empresaId) || isExistingOwner(resource.data.ownerId);

      // Subcoleções simplificadas para permitir acesso total ao dono da empresa (empresaId == uid)
      match /servicos/{servicoId} {
        allow read, write: if isOwner(empresaId);
      }

      match /colaboradores/{colaboradorId} {
        allow read, write: if isOwner(empresaId);
      }

      match /clientes/{clienteId} {
        allow read, write: if isOwner(empresaId);
      }

      match /agendamentos/{agendamentoId} {
        allow read, write: if isOwner(empresaId);
      }
    }
  }
}