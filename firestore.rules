rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Regra para Perfis de Usuários
    match /perfis_usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 2. Regra para Empresas e todas as suas Subcoleções
    // Esta estrutura aninhada é a mais robusta para garantir que o dono
    // tenha acesso total (incluindo listagem) a agendamentos, serviços, etc.
    match /empresas/{empresaId} {
      allow read, write: if request.auth != null && request.auth.uid == empresaId;
      
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == empresaId;
      }
    }
    
    // Bloqueio padrão para qualquer outra coleção não mapeada
    match /{document=**} {
      allow read, write: if false;
    }
  }
}