rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regra para perfis de usuários
    match /perfis_usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regra para Empresas e Subcoleções
    match /empresas/{empresaId} {
      // Permite ler/escrever o documento da própria empresa
      allow read, write: if request.auth != null && request.auth.uid == empresaId;

      // Regras explícitas para subcoleções (agendamentos, serviços, colaboradores)
      // O uso do curinga recursivo {allPaths=**} garante que qualquer caminho 
      // abaixo de uma empresa seja acessível apenas pelo seu dono.
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == empresaId;
      }
    }
    
    // Bloqueio preventivo padrão
    match /{document=**} {
      allow read, write: if false;
    }
  }
}