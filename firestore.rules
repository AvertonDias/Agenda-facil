
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Regra para Perfis de Usuários
    match /perfis_usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 2. Regra para o DOCUMENTO da Empresa e suas SUBCOLEÇÕES
    // Utilizamos o curinga recursivo {allPaths=**} para garantir que o proprietário
    // tenha acesso total a toda a sua árvore de dados.
    match /empresas/{empresaId} {
      allow read, write: if request.auth != null && request.auth.uid == empresaId;
      
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == empresaId;
      }
    }
    
    // Bloqueio preventivo padrão para qualquer outro caminho
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
