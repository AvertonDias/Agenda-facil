rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regra para perfis de usuários
    match /perfis_usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regra para Empresas e Subcoleções
    match /empresas/{empresaId} {
      // Permite ler/escrever o documento da própria empresa
      allow read, write: if request.auth != null && request.auth.uid == empresaId;

      // Regras explícitas para subcoleções para evitar erros de 'list'
      match /agendamentos/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == empresaId;
      }
      
      match /servicos/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == empresaId;
      }
      
      match /colaboradores/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == empresaId;
      }

      // Cobre qualquer outro caminho aninhado
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == empresaId;
      }
    }
    
    // Bloqueio preventivo padrão
    match /{document=**} {
      allow read, write: if false;
    }
  }
}