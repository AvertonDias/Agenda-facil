rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regra para perfis de usuários
    match /perfis_usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regra para Empresas e suas Subcoleções
    match /empresas/{empresaId} {
      // Permite ler/escrever o documento da própria empresa
      allow read, write: if request.auth != null && request.auth.uid == empresaId;

      // Regra ULTRA-EXPLÍCITA para agendamentos
      // 'read' cobre 'get' e 'list'
      match /agendamentos/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == empresaId;
      }

      // Regra ULTRA-EXPLÍCITA para servicos
      match /servicos/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == empresaId;
      }

      // Regra ULTRA-EXPLÍCITA para colaboradores
      match /colaboradores/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == empresaId;
      }

      // Cobertura recursiva para qualquer outra subcoleção futura
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && request.auth.uid == empresaId;
      }
    }
    
    // Bloqueio preventivo padrão
    match /{document=**} {
      allow read, write: if false;
    }
  }
}