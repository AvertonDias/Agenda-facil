/**
 * Firebase Firestore Security Rules - AgendaFácil Pro
 * 
 * Modelo de segurança baseado em caminho (Path-based ownership).
 * O usuário tem acesso total a documentos onde o ID ou o caminho contém seu UID.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper para verificar se o usuário está logado
    function isSignedIn() {
      return request.auth != null;
    }

    // Regra para Perfis de Usuários
    match /perfis_usuarios/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Regras para Empresas e todas as suas subcoleções (servicos, colaboradores, agendamentos)
    // Usamos o empresaId como o UID do dono para simplificar a verificação de permissão.
    match /empresas/{empresaId} {
      allow read, write: if isSignedIn() && request.auth.uid == empresaId;
      
      // Permite acesso a qualquer documento em qualquer subcoleção dentro desta empresa
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == empresaId;
      }
    }
    
    // Regra global de segurança (bloqueia tudo que não foi explicitamente permitido)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}