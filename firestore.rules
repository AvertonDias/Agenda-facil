
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regra para perfis
    match /perfis_usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regra para Empresas e Subcoleções
    match /empresas/{empresaId} {
      // Permite ler o documento da empresa
      allow read, write: if request.auth != null && request.auth.uid == empresaId;

      // Permite LISTAR e LER agendamentos de forma explícita
      match /agendamentos/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == empresaId;
      }

      // Permite qualquer outra subcoleção de forma recursiva
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && request.auth.uid == empresaId;
      }
    }
    
    // Bloqueio preventivo padrão
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
